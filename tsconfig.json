{
  "extends": "./tsconfig.base.json",
  "include": [
    "apps/web/client/src/**/*",
    "apps/server/**/*",
    "packages/**/*",
    "api/**/*",
    "script/**/*",
    "drizzle.config.ts"
  ],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "types": ["node", "vite/client"]
  }
}
