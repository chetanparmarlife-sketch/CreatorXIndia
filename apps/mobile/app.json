{
  "expo": {
    "name": "CreatorX",
    "slug": "creatorx",
    "scheme": "creatorx",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.creatorx.mobile"
    },
    "android": {
      "package": "app.creatorx.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
